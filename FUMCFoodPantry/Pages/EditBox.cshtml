@page
@using RazorPagesMovie.Pages
@model EditBoxModel
@{
    ViewData["Title"] = "Edit Weekly Box";
}

<head>
    <title>Edit Weekly Box</title>

    <style>
  label{
    font-size: 24px;
    }


.OrderForm {
    width: 100%;
    max-width: 500px; 
}  
</style>
</head>



<body>

<div class="container mb-5">
    <div class="row">
<div class="col-md-6">
<div>
    <h4>Select Items for Main Box</h4>
</div>
<div>
    <label for="Tier 1">Choose 1 Tier 1 items:</label>
</div>
<div>
    <select id="SelectedItem" name="SelectedItem">
    @foreach (var item in Model.Stock)
    {
        <option value="@item.Item">@item.Item</option>
    }
    </select>
</div>
<div>
<label for="Tier 2">Choose 2 Tier 2 items:</label>
</div>
<div>
<select id="SelectedItem" name="SelectedItem">
    @foreach (var item in Model.Stock)
    {
        <option value="@item.Item">@item.Item</option>
    }
    </select>
<select id="SelectedItem" name="SelectedItem">
    @foreach (var item in Model.Stock)
    {
        <option value="@item.Item">@item.Item</option>
    }
    </select>
</div>
<div>
<div>
<label for="Tier 3">Choose 1 Tier 3 item:</label>
</div>
<div>
<select id="SelectedItem" name="SelectedItem">
    @foreach (var item in Model.Stock)
    {
        <option value="@item.Item">@item.Item</option>
    }
    </select>
</div>
</div>
</div>
<div class="col-md-6">
<div>
    <h4>Select Items for Alternative Box</h4>
</div>
<div>
    <label for="Tier 1">Choose 1 Tier 1 items:</label>
</div>
<div>
    <select id="SelectedItem" name="SelectedItem">
    @foreach (var item in Model.Stock)
    {
        <option value="@item.Item">@item.Item</option>
    }
    </select>
</div>
<div>
<label for="Tier 2">Choose 2 Tier 2 items:</label>
</div>
<div>
<select id="SelectedItem" name="SelectedItem">
    @foreach (var item in Model.Stock)
    {
        <option value="@item.Item">@item.Item</option>
    }
    </select>
<select id="SelectedItem" name="SelectedItem">
    @foreach (var item in Model.Stock)
    {
        <option value="@item.Item">@item.Item</option>
    }
    </select>
</div>
<div>
<div>
<label for="Tier 3">Choose 1 Tier 3 item:</label>
</div>
<div>
<select id="SelectedItem" name="SelectedItem">
    @foreach (var item in Model.Stock)
    {
        <option value="@item.Item">@item.Item</option>
    }
    </select>
</div>
</div>
</div>
</div>
</div>

<input type="button" value="Save Boxes">



