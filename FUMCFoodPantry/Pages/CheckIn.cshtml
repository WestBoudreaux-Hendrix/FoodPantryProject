@page
@using RazorPagesMovie.Pages
@model CheckInModel
@{
    ViewData["Title"] = "Drive-Thru Check In";
}

<head>
    <title>Drive-Thru Check In</title>
</head>



<body>

<div class="container-fluid pt-5 text-center">
    <h2>@ViewData["Title"]</h2>
</div>

<div class="col text-center p-3">
  <h4>Today's Options</h4>

  <div class="row gx-4 gx-lg-5 mt-3">
                <div class="col-md-6 mb-5">
                    <div class="card h-100">
                        <div class="card-body mb-4">
                            <h5 class="card-title text-center">Box 1</h5>
                            <p class="card-text">(Main box info goes here)</p>
                            <div class="card-footer text-center">
                                <p>Select Amount:</p>
                                <input type="number" style="margin-left: 10px; height: 30px; width: 30px;"> 
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-5">
                    <div class="card h-100">
                        <div class="card-body mb-4">
                            <h5 class="card-title text-center">Box 2</h5>
                            <p class="card-text">(Alternative box info goes here)</p>
                            <div class="card-footer text-center">
                                <p>Select Amount:</p>
                                <input type="number" style="margin-left: 10px; height: 30px; width: 30px;"> 
                            </div>
                        </div>
                    </div>
                </div>
            </div>
<a class="btn btn-primary btn-md" asp-page="/InLine">Confirm Choices</a>
</div>


<script src="https://code.jquery.com/jquery-3.4.1.slim.min.js" integrity="sha384-J6qa4849blE2+poT4WnyKhv5vZF5SrPo0iEjwBvKU7imGFAV0wwj1yYfoRSJoZ+n" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js" integrity="sha384-Q6E9RHvbIyZFJoft+2mJbHaEWldlvI9IOYy5n3zV9zzTtmI3UksdQRVvoxMfooAo" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.4.1/dist/js/bootstrap.min.js" integrity="sha384-wfSDF2E50Y2D1uUdj0O3uMBJnjuUD4Ih7YwaYd1iqfktj0Uod8GCExl3Og8ifwB6" crossorigin="anonymous"></script>
</body>