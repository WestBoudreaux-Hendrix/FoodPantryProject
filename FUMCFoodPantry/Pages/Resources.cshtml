@page
@model ResourcesModel
@{
    ViewData["Title"] = "Resources";
}



<h1>@ViewData["Title"]</h1>

<p>Here would be lots of different resources the food bank makes available alongside other in the area. Ideally this page
    is a centralized location for any type of resource we can think to include that may be of use to the community members.
</p>


<div class="row gx-4 gx-lg-5 pb-5 mb-5">

                <div class="col-md-6 mb-5">
                    <div class="card h-100">
                        <div class="card-body mb-4">
                            <h3 class="card-title text-center mb-3">Food Pantries</h3>
                            <h5><a href="https://www.antiochconway.com/care">Antioch Baptist Church</a></h5>
                            <p class="ml-5">150 Amity Road, Conway, AR <br>501-329-5153<br>Food Pantry: Thursdays 10am-11am & 6:30pm-7:30pm <br>*Bring Photo ID* </p>
                            
                            <h5><a href="https://www.bethlehemhouse.net">Bethlehem House</a></h5>
                            <p class="ml-5">1115 Parkway Street, Conway, AR <br>501-329-4862<br>Daily Hot Breakfast: 6am-8am <br>Daily Hot Lunch: 12pm-1pm </p>

                            <h5><a href="https://www.salemumcconway.org/">Salem United Methodist Church</a></h5>
                            <p class="ml-5">1018 Salem Road, Conway, AR <br>501-327-2884<br>Food Pantry: Thursdays 1pm-3pm <br>*Bring Photo ID*<br>Sharing Fridge: Open 24/7</p>

                            <h5><a href="https://www.soulfoodcafemission.org/schedule">Soul Food Cafe</a></h5>
                            <p class="ml-5">1717 S Donaghey Ave, Conway, AR<br>501-575-2929 <br>Open Tuesdays 9am-3pm <br>Hot Lunch: 11:30am <br>Food Baskets: 1pm-3pm <br>*Bring Photo ID* </p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-5">
                    <div class="card h-100">
                        <div class="card-body mb-4">
                            <h3 class="card-title text-center mb-3">Shelters</h3>
                            <h5><a href="https://www.bethlehemhouse.net">Bethlehem House</a></h5>
                            <p class="ml-5">1115 Parkway Street, Conway, AR <br>501-329-4862 <br>Emergency shelter and traditional housing program.</p>

                            <h5><a href="https://capcainc.org/posts/unsheltered-support">CAPCA Conway Emergency Shelter</a></h5>
                            <p class="ml-5">1116 Gum Street, Conway, AR <br>501-329-3891 | 501-329-0977<br>Overnight shelter for adults 18 and older.<br />Beds open at 4pm, first come, first serve</p>

                        </div>
                    </div>
                </div>

