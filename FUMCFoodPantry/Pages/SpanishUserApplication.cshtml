                <input asp-for="UserApplications.Family2Gender" class="form-control" />
                <span asp-validation-for="UserApplications.Family2Gender" class="text-danger"></span>
                <label asp-for="UserApplications.Family2Relationship" class="control-label">Familiar 2: Parentesco con usted</label>
                <input asp-for="UserApplications.Family2Relationship" class="form-control" />
