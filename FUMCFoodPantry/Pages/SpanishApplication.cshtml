@page
@using RazorPagesMovie.Pages
@model SpanishApplicationModel
@{
    ViewData["Title"] = "Solicitud de asistencia";
}

<head>
    <title>Solicitud de asistencia</title>
</head>

<style>
.appSect {
  border-width:2px; 
  border-style:solid; 
  border-color: #999;
  padding: 30px;
}
</style>

<body>
    <div class="container-fluid pt-5 text-center">
    <h3>@ViewData["Title"]</h3>
    </div>

<div class="col text-left p-3">
    <b>1. Nombre</b>
    <div class="mb-3 appSect">
        <input type="text" placeholder="apellido">
        <input type="text" placeholder="nombre de pila">
        <input type="text" placeholder="Inicial del segundo nombre">
    </div>
    <b>2. DIRECCIÓN</b>
    <div class="mb-3 appSect">
    <div class="d-flex">
        <p>¿Tiene una dirección fija?</p>
        <div style="margin-left: 10px;">
            <input type="radio" id="yes" value="yes" name="fixedAddress"/> 
            <label for="yes" style="text-align: center; margin-right: 10px;">Sí</label>
            <input type="radio" id="no" value="no" name="fixedAddress"/>
            <label for="no" style="text-align: center; margin-right: 10px;">No</label>
        </div>
    </div>
    <div class="mb-3">
        <input type="text" placeholder="DIRECCIÓN">
        <input type="text" placeholder="Ciudad">
        <input type="text" placeholder="Estado">
        <input type="text" placeholder="Código postal">
        <input type="text" placeholder="Condado">
    </div>
    </div>
    <b>3. Información personal</b>
    <div class="mb-3 appSect">
    <div class="mb-3">
        <input type="tel" placeholder="Número de teléfono"> 
    </div>
    <div class="mb-3 d-flex">
        <p>Fecha de nacimiento:</p>
        <input type="date" style="margin-left: 10px; height: 30px;"> 
    </div>
    <div class="mb-3 d-flex">
        <p>¿Cuál es su situación laboral?</p>
        <div style="margin-left: 10px;">
            <input type="radio" id="fullTime" value="yes" name="employmentStatus"/> 
            <label for="fullTime" style="text-align: center; margin-right: 10px;">Jornada completa</label>
            <input type="radio" id="partTime" value="partTime" name="employmentStatus"/>
            <label for="partTime" style="text-align: center; margin-right: 10px;">Tiempo parcial</label>
            <input type="radio" id="unemployed" value="unemployed" name="employmentStatus"/>
            <label for="unemployed" style="text-align: center; margin-right: 10px;">Desempleados</label>
            <input type="radio" id="retired" value="retired" name="employmentStatus"/>
            <label for="retired" style="text-align: center; margin-right: 10px;">Jubilado</label>
            <input type="radio" id="disabled" value="disabled" name="employmentStatus"/>
            <label for="disabled" style="text-align: center; margin-right: 10px;">Desactivado</label>
        </div>
    </div>
    <div class="mb-3 d-flex">
        <p>¿Cuál es su situación de vivienda actual?</p>
        <div style="margin-left: 10px;">
            <input type="radio" id="own" value="own" name="housingStatus"/>
            <label for="own" style="text-align: center; margin-right: 10px;">Propio</label>
            <input type="radio" id="rent" value="rent" name="housingStatus"/>
            <label for="rent" style="text-align: center; margin-right: 10px;">Alquilar</label>
            <input type="radio" id="homeless" value="homeless" name="housingStatus"/>
            <label for="homeless" style="text-align: center; margin-right: 10px;">Sin hogar</label>
            <input type="radio" id="transient" value="transient" name="housingStatus"/>
            <label for="transient" style="text-align: center; margin-right: 10px;">Transitorio</label>
            <input type="radio" id="atRisk" value="atRisk" name="housingStatus"/>
            <label for="atRisk" style="text-align: center; margin-right: 10px;">En riesgo de quedarse sin hogar</label>
        </div>
    </div>
    <div class="mb-3 d-flex">
        <p>¿Es usted el contacto principal de su hogar?</p>
        <div style="margin-left: 10px;">
            <input type="radio" id="yes" value="yes" name="primaryContact"/> 
            <label for="yes" style="text-align: center; margin-right: 10px;">Sí</label>
            <input type="radio" id="no" value="no" name="primaryContact"/>
            <label for="no" style="text-align: center; margin-right: 10px;">No</label>
        </div>
    </div>
    <div class="mb-3 d-flex">
        <p>¿Cuál es su género? (Autoidentificado)</p>
        <div style="margin-left: 10px;">
            <input type="radio" id="female" value="female" name="gender"/> 
            <label for="female" style="text-align: center; margin-right: 10px;">Femenina</label>
            <input type="radio" id="male" value="male" name="gender"/>
            <label for="male" style="text-align: center; margin-right: 10px;">Masculino</label>
            <input type="radio" id="nonBinary" value="nonBinary" name="gender"/>
            <label for="nonBinary" style="text-align: center; margin-right: 10px;">No binario</label>
            <input type="radio" id="other" value="other" name="gender"/>
            <label for="other" style="text-align: center; margin-right: 10px;">Otro</label>
            <input type="radio" id="preferNotToSay" value="preferNotToSay" name="gender"/>
            <label for="preferNotToSay" style="text-align: center; margin-right: 10px;">Prefiero no decirlo</label>
        </div>
    </div>
    <div class="mb-3">
        <p>¿Cuál es tu raza? (Selecciona todas las que correspondan)</p>
        <div style="margin-left: 10px;">
            <input type="checkbox" id="white" value="white" name="race"/> 
            <label for="white" style="text-align: center; margin-right: 10px;">Blanco</label>
            <input type="checkbox" id="black" value="black" name="race"/>
            <label for="black" style="text-align: center; margin-right: 10px;">Negro o afroamericano</label>
            <input type="checkbox" id="asian" value="asian" name="race"/>
            <label for="asian" style="text-align: center; margin-right: 10px;">Asiático</label>
            <input type="checkbox" id="hispanic" value="hispanic" name="race"/>
            <label for="hispanic" style="text-align: center; margin-right: 10px;">Hispano, latino o español</label>
            <input type="checkbox" id="nativeAmerican" value="nativeAmerican" name="race"/>
            <label for="nativeAmerican" style="text-align: center; margin-right: 10px;">Nativo americano o nativo de Alaska</label>
            <input type="checkbox" id="middleEastern" value="middleEastern" name="race"/>
            <label for="middleEastern" style="text-align: center; margin-right: 10px;">De Oriente Medio o del Norte de África</label>
            <input type="checkbox" id="marshallese" value="marshallese" name="race"/>
            <label for="marshallese" style="text-align: center; margin-right: 10px;">Marshallés</label>
            <input type="checkbox" id="hawaiian" value="hawaiian" name="race"/>
            <label for="hawaiian" style="text-align: center; margin-right: 10px;">Nativo hawaiano / otro isleño del Pacífico</label>
            <input type="checkbox" id="other" value="other" name="race"/>
            <label for="other" style="text-align: center; margin-right: 10px;">Otra raza o etnia</label>
            <input type="checkbox" id="preferNotToSay" value="preferNotToSay" name="race"/>
            <label for="preferNotToSay" style="text-align: center; margin-right: 10px;">Prefiero no decirlo</label>
        </div>
    </div>
    </div>
    <b>4. Información del hogar</b>
    <div class="mb-3 appSect">
    <div class="d-flex">
        <p>Seleccione todo lo que se aplique a su hogar.</p>
        <div style="margin-left: 10px;">
            <input type="checkbox" id="singleParent" value="singleParent" name="household"/> 
            <label for="singleParent" style="text-align: center; margin-right: 10px;">Padre o madre soltero/a</label>
            <input type="checkbox" id="adultAlone" value="adultAlone" name="household"/>
            <label for="adultAlone" style="text-align: center; margin-right: 10px;">Adulto que vive solo</label>
            <input type="checkbox" id="disabled" value="disabled" name="household"/>
            <label for="disabled" style="text-align: center; margin-right: 10px;">Hogar discapacitado</label>
            <input type="checkbox" id="multigenerational" value="multigenerational" name="household"/>
            <label for="multigenerational" style="text-align: center; margin-right: 10px;">Hogar multigeneracional</label>
        </div>
    </div>
    <div class="mb-3">
        <p>¿Alguna persona de su hogar, incluido usted, tiene una discapacidad que le impida aceptar cualquier tipo de trabajo durante los próximos 6 meses?</p>
        <div style="margin-left: 10px;">
            <input type="radio" id="yes" value="yes" name="disability6mos"/> 
            <label for="yes" style="text-align: center; margin-right: 10px;">Sí</label>
            <input type="radio" id="no" value="no" name="disability6mos"/>
            <label for="no" style="text-align: center; margin-right: 10px;">No</label>
            <input type="radio" id="dontKnow" value="dontKnow" name="disability6mos"/>
            <label for="dontKnow" style="text-align: center; margin-right: 10px;">No sé</label>
        </div>
    </div>
    <div class="mb-3">
        <p>¿Hay alguien en su hogar que sea militar en activo?</p>
        <div style="margin-left: 10px;">
            <input type="radio" id="yes" value="yes" name="activeMilitary"/> 
            <label for="yes" style="text-align: center; margin-right: 10px;">Sí</label>
            <input type="radio" id="no" value="no" name="activeMilitary"/>
            <label for="no" style="text-align: center; margin-right: 10px;">No</label>
        </div>
    </div>
    <div class="mb-3">
        <p>¿Hay algún veterano en su hogar?</p>
        <div style="margin-left: 10px;">
            <input type="radio" id="yes" value="yes" name="veteran"/> 
            <label for="yes" style="text-align: center; margin-right: 10px;">Sí</label>
            <input type="radio" id="no" value="no" name="veteran"/>
            <label for="no" style="text-align: center; margin-right: 10px;">No</label>
        </div>
    </div>
    <div class="mb-3">
        <p>¿Alguna persona de su hogar recibe SNAP (cupones de alimentos)?</p>
        <div style="margin-left: 10px;">
            <input type="radio" id="yes" value="yes" name="snap"/> 
            <label for="yes" style="text-align: center; margin-right: 10px;">Sí</label>
            <input type="radio" id="no" value="no" name="snap"/>
            <label for="no" style="text-align: center; margin-right: 10px;">No</label>
        </div>
    </div>
    <div class="mb-3">
        <p>Por favor, enumere a todos los miembros que residen en el hogar (excluyéndose a usted mismo).</p>
        <input type="text" placeholder="Nombre y apellido">
        <input type="text" placeholder="Fecha de nacimiento (MM/DD/AAAA)">
        <input type="text" placeholder="Etnia">
        <input type="text" placeholder="Género">
        <input type="text" placeholder="Relación contigo">
        <input type="text" placeholder="Ingresos (Monto)">
    </div>
    <div class="mb-3">
        <input type="text" placeholder="Nombre y apellido">
        <input type="text" placeholder="Fecha de nacimiento (MM/DD/AAAA)">
        <input type="text" placeholder="Etnia">
        <input type="text" placeholder="Género">
        <input type="text" placeholder="Relación contigo">
        <input type="text" placeholder="Ingresos (Monto)">
    </div>
    <div class="mb-3">
        <input type="text" placeholder="Nombre y apellido">
        <input type="text" placeholder="Fecha de nacimiento (MM/DD/AAAA)">
        <input type="text" placeholder="Etnia">
        <input type="text" placeholder="Género">
        <input type="text" placeholder="Relación contigo">
        <input type="text" placeholder="Ingresos (Monto)">
    </div>
    <div class="mb-3">
        <input type="text" placeholder="Nombre y apellido">
        <input type="text" placeholder="Fecha de nacimiento (MM/DD/AAAA)">
        <input type="text" placeholder="Etnia">
        <input type="text" placeholder="Género">
        <input type="text" placeholder="Relación contigo">
        <input type="text" placeholder="Ingresos (Monto)">
    </div>
    <div class="mb-3">
        <input type="text" placeholder="Nombre y apellido">
        <input type="text" placeholder="Fecha de nacimiento (MM/DD/AAAA)">
        <input type="text" placeholder="Etnia">
        <input type="text" placeholder="Género">
        <input type="text" placeholder="Relación contigo">
        <input type="text" placeholder="Ingresos (Monto)">
    </div>
    <div class="mb-3">
        <input type="text" placeholder="Nombre y apellido">
        <input type="text" placeholder="Fecha de nacimiento (MM/DD/AAAA)">
        <input type="text" placeholder="Etnia">
        <input type="text" placeholder="Género">
        <input type="text" placeholder="Relación contigo">
        <input type="text" placeholder="Ingresos (Monto)">
    </div>
    </div>
    <input type="button" value="Hecho">
</div>
</body>